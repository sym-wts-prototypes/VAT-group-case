{
  "name": "wts-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "gallery": "pnpm --filter @wts/gallery dev",
    "gen:prototype": "node scripts/new-prototype.mjs",
    "figma:parse": "npx figma connect parse",
    "figma:publish": "npx figma connect publish",
    "assemble": "node scripts/assemble-dist.mjs",
    "snapshots": "node scripts/snapshot.mjs",
    "preview": "pnpm --filter @wts/worker dev",
    "deploy": "pnpm --filter @wts/worker deploy"
  },
  "devDependencies": {
    "playwright": "^1.49.0",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
